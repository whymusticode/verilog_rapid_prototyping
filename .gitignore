# === Xilinx Vivado ===

# Vivado project internals (regenerated by build.tcl)
*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
*.srcs/
*.gen/
.Xil/

# Vivado journals and logs
*.jou
*.log
*.backup.jou
*.backup.log

# Simulation artifacts
xsim.dir/
*.wdb
*.vcd
*.pb
*.str
*.xpe

# Synthesis / implementation outputs (regenerated from source)
*.bit
*.bin
*.ltx
*.mmi
*.dcp
*.rpt

# Vivado HLS
*.aps
*.apc
solution*/.autopilot/
solution*/impl/
solution*/sim/
solution*/csim/

# === Python ===
__pycache__/
*.pyc
*.pyo

# === macOS ===
.DS_Store

# === Java (Vivado crash logs) ===
hs_err_pid*.log

# === Misc generated files ===
.functions
