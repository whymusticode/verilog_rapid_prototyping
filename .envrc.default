
# ---- Vivado backend ----
# Discriminates how vivado is invoked on this machine.
# One of: native | flatpak | docker. Leave unset (or set to "auto") to auto-detect.
# Override by exporting VIVADO_BACKEND before sourcing this file.
if [ -z "${VIVADO_BACKEND:-}" ] || [ "${VIVADO_BACKEND}" = "auto" ]; then
  if command -v vivado >/dev/null 2>&1; then
    export VIVADO_BACKEND=native
  elif command -v flatpak >/dev/null 2>&1 && \
       flatpak info "${VIVADO_FLATPAK_APP:-com.github.corna.Vivado}" >/dev/null 2>&1; then
    export VIVADO_BACKEND=flatpak
  elif command -v docker >/dev/null 2>&1; then
    export VIVADO_BACKEND=docker
  else
    unset VIVADO_BACKEND
  fi
fi

export VIVADO_NATIVE_BIN="${VIVADO_NATIVE_BIN:-vivado}"
export VIVADO_FLATPAK_APP="${VIVADO_FLATPAK_APP:-com.github.corna.Vivado}"
export VIVADO_DOCKER_IMAGE="${VIVADO_DOCKER_IMAGE:-vivado:latest}"
export VIVADO_DOCKER_BIN="${VIVADO_DOCKER_BIN:-/opt/Xilinx/Vivado/2024.1/bin/vivado}"
export VITIS_HLS_BIN="${VITIS_HLS_BIN:-/opt/Xilinx/Vitis_HLS/2024.1/bin/vitis_hls}"
# Apple Silicon hosts should usually set linux/amd64 for Xilinx tool images.
export VIVADO_DOCKER_PLATFORM="${VIVADO_DOCKER_PLATFORM:-linux/amd64}"

