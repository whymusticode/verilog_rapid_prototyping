# ---- Vivado/Vitis tool paths ----
# Keep these override-friendly: explicit env vars win over auto detection.
if [ -z "${VIVADO_NATIVE_BIN:-}" ]; then
  if command -v vivado >/dev/null 2>&1; then
    export VIVADO_NATIVE_BIN=vivado
  else
    for p in /tools/Xilinx/*/Vivado/bin/vivado /opt/Xilinx/Vivado/*/bin/vivado; do
      [ -x "$p" ] && export VIVADO_NATIVE_BIN="$p" && break
    done
    [ -z "${VIVADO_NATIVE_BIN:-}" ] && export VIVADO_NATIVE_BIN=vivado
  fi
fi

if [ -z "${VITIS_HLS_BIN:-}" ]; then
  if command -v vitis_hls >/dev/null 2>&1; then
    export VITIS_HLS_BIN=vitis_hls
  else
    for p in /tools/Xilinx/*/Vitis_HLS/*/bin/vitis_hls \
             /opt/Xilinx/Vitis_HLS/*/bin/vitis_hls \
             /tools/Xilinx/*/Vitis/bin/vitis-run \
             /opt/Xilinx/Vitis/*/bin/vitis-run; do
      [ -x "$p" ] && export VITIS_HLS_BIN="$p" && break
    done
    [ -z "${VITIS_HLS_BIN:-}" ] && command -v vitis-run >/dev/null 2>&1 && export VITIS_HLS_BIN=vitis-run
    [ -z "${VITIS_HLS_BIN:-}" ] && export VITIS_HLS_BIN=vitis_hls
  fi
fi

# ---- Vivado backend ----
# Discriminates how vivado is invoked on this machine.
# One of: native | flatpak | docker. Leave unset (or set to "auto") to auto-detect.
# Override by exporting VIVADO_BACKEND before sourcing this file.
if [ -z "${VIVADO_BACKEND:-}" ] || [ "${VIVADO_BACKEND}" = "auto" ]; then
  if command -v "${VIVADO_NATIVE_BIN}" >/dev/null 2>&1; then
    export VIVADO_BACKEND=native
  elif command -v flatpak >/dev/null 2>&1 && \
       flatpak info "${VIVADO_FLATPAK_APP:-com.github.corna.Vivado}" >/dev/null 2>&1; then
    export VIVADO_BACKEND=flatpak
  elif command -v docker >/dev/null 2>&1; then
    export VIVADO_BACKEND=docker
  else
    unset VIVADO_BACKEND
  fi
fi

export VIVADO_FLATPAK_APP="${VIVADO_FLATPAK_APP:-com.github.corna.Vivado}"
export VIVADO_DOCKER_IMAGE="${VIVADO_DOCKER_IMAGE:-vivado-vitis-2024.1.1:local}"
export VIVADO_DOCKER_PLATFORM="${VIVADO_DOCKER_PLATFORM:-linux/amd64}"
export VIVADO_DOCKER_BIN="${VIVADO_DOCKER_BIN:-/opt/Xilinx/Vivado/2024.1/bin/vivado}"

