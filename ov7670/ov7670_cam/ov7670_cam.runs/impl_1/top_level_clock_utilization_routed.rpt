# Location of BUFG Primitives 
set_property LOC BUFGCTRL_X0Y1 [get_cells ov7670_pclk_IBUF_BUFG_inst]
set_property LOC BUFGCTRL_X0Y2 [get_cells clk_inst/buf50]
set_property LOC BUFGCTRL_X0Y0 [get_cells clk_inst/buf25]

# Location of IO Primitives which is load of clock spine

# Location of clock ports
set_property LOC IOB_X1Y26 [get_ports clk100]
set_property LOC IOB_X0Y24 [get_ports ov7670_pclk]

# Clock net "ov7670_pclk_IBUF_BUFG" driven by instance "ov7670_pclk_IBUF_BUFG_inst" located at site "BUFGCTRL_X0Y1"
#startgroup
create_pblock {CLKAG_ov7670_pclk_IBUF_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_ov7670_pclk_IBUF_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="ov7670_pclk_IBUF_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_ov7670_pclk_IBUF_BUFG}] -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y0 CLOCKREGION_X0Y1:CLOCKREGION_X0Y1 CLOCKREGION_X1Y0:CLOCKREGION_X1Y0 CLOCKREGION_X1Y1:CLOCKREGION_X1Y1}
#endgroup

# Clock net "clk_inst/CLK_50" driven by instance "clk_inst/buf50" located at site "BUFGCTRL_X0Y2"
#startgroup
create_pblock {CLKAG_clk_inst/CLK_50}
add_cells_to_pblock [get_pblocks  {CLKAG_clk_inst/CLK_50}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="clk_inst/CLK_50"}]]]
resize_pblock [get_pblocks {CLKAG_clk_inst/CLK_50}] -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y0}
#endgroup

# Clock net "clk_inst/CLK_25" driven by instance "clk_inst/buf25" located at site "BUFGCTRL_X0Y0"
#startgroup
create_pblock {CLKAG_clk_inst/CLK_25}
add_cells_to_pblock [get_pblocks  {CLKAG_clk_inst/CLK_25}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="clk_inst/CLK_25"}]]]
resize_pblock [get_pblocks {CLKAG_clk_inst/CLK_25}] -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y0 CLOCKREGION_X0Y1:CLOCKREGION_X0Y1 CLOCKREGION_X1Y0:CLOCKREGION_X1Y0 CLOCKREGION_X1Y1:CLOCKREGION_X1Y1}
#endgroup
